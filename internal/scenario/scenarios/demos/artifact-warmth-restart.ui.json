{
  "schema": "mercator.lab/ui-checkpoints.v1",
  "checkpoints": [
    {
      "id": "producer-placement-visible",
      "after": {
        "event": "compute.run.booking_decided.v1",
        "run": "producer"
      },
      "assertions": [
        {
          "role": "link",
          "name": "run-producer:"
        }
      ]
    },
    {
      "id": "consumer-artifact-locality-visible",
      "after": {
        "event": "compute.run.booking_decided.v1",
        "run": "consumer"
      },
      "assertions": [
        {
          "role": "link",
          "name": "run-consumer:"
        }
      ],
      "screenshot": true
    },
    {
      "id": "terminal-lifecycle-visible",
      "after": {
        "event": "compute.run.closed.v1",
        "run": "consumer"
      },
      "assertions": [
        {
          "role": "button",
          "name": "Closed"
        }
      ],
      "screenshot": true
    }
  ]
}
