{
  "summary": "A warm Rental has one short RunningPlacement and fresh capacity is slow. Two arriving Runs both receive durable ScheduledPlacements in submission order because the full ordered wait remains faster than provisioning.",
  "status": "target",
  "world": {
    "images": {
      "worker:v1": {
        "layers": [
          {"name": "worker-base", "size": "4GB"},
          {"name": "worker-code-v1", "size": "20MB"}
